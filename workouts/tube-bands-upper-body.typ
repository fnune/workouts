#import "../template.typ": *

#show: workout.with(
  title: "Upper body",
  equipment: "tube bands · door anchor · towel",
)

#warmup[
  arm circles forward, arm circles backward, shoulder rolls, cat-cow, pull-aparts · 10 each
]

#exercise(
  "Band Lat Pulldown",
  "3 × 10–12",
  "Anchor at top of door. Kneel facing door. A handle in each hand, arms overhead. Pull elbows down to ribs, scapulae depressing. Control on return.",
)

#exercise(
  "Band Overhead Press",
  "3 × 8–10",
  "Stand on tube center, feet shoulder-width. A handle in each hand at shoulder height. Press straight overhead. Ribs stacked over hips, glutes engaged.",
)

#exercise(
  "Band Row (towel grip)",
  "3 × 10–12",
  "Anchor at belly height in door. Step back until band is taut. Towel wrapped around each handle (grip work). Pull handles to ribs, scapular retraction.",
)

#exercise(
  "Push-up",
  "3 × max reps - 2",
  "Hands directly under shoulders. Body in one line, heels to crown. Lower under control. Each set ends 2 reps short of failure.",
)

#exercise(
  "Pallof Press",
  "3 × 10 / side",
  "Anchor at chest height. Stand at 90° to door, step away until band is taut. Both handles stacked at sternum. Press straight out, resist rotation. Return slow.",
)

#exercise(
  "Band Pull-Apart",
  "2 × 15",
  "A handle in each hand. Wrap tube once around each wrist until band is taut with arms extended forward. Pull handles wide to chest, scapular retraction.",
)

#exercise(
  "Neck Isometrics",
  "2 × 20 s × 4 directions",
  "Hand presses forehead, head pushes back: isometric hold. Repeat at back of head, left, right. Light, controlled pressure.",
)
