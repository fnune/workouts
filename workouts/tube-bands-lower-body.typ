#import "../template.typ": *

#show: workout.with(
  title: "Lower body",
  equipment: "tube bands · door anchor · ankle strap · couch",
)

#warmup[
  hip circles, leg swings front-back, leg swings lateral, bodyweight squats, ankle circles · 10 each
]

#exercise(
  "Band Goblet Squat",
  "3 × 10–12",
  "Stand on tube center, feet shoulder-width. Both handles stacked at sternum. Descend until thighs ~parallel to floor, knees track over toes. Drive up.",
)

#exercise(
  "Single-Leg Romanian Deadlift",
  "3 × 8 / side",
  "Stand on tube with working-side foot. Both handles in opposite hand. Hip hinge with neutral spine: free leg extends behind to ~horizontal. Return to upright.",
)

#exercise(
  "Bulgarian Split Squat",
  "3 × 8 / side",
  "Front foot on tube center. Rear foot elevated on couch. A handle in each hand at shoulder height. Descend vertically, front shin near vertical. Drive up through front heel.",
)

#exercise(
  "Banded Knee Drive",
  "3 × 10 / side",
  "Ankle strap on working foot. Other end anchored low behind you. Step forward until band is taut. Drive knee to chest, fast. Return under control.",
)

#exercise(
  "Suitcase Hold / March",
  "2 × 30 s / side",
  "Step on tube center (band doubles under foot). Same-side hand grips one handle at hip; other handle hangs free. Neutral spine, no lateral lean. March in place.",
)

#exercise(
  "Neck Isometrics",
  "2 × 20 s × 4 directions",
  "Hand presses forehead, head pushes back: isometric hold. Repeat at back of head, left, right. Light, controlled pressure.",
)
